import java.util.*;

public class UPTMMarketingOptimize {
    static int[][] costMatrix = {
        {0, 15, 25, 35},
        {15, 0, 30, 28},
        {25, 30, 0, 20},
        {35, 28, 20, 0}
    };

    static String[] locations = {"UPTM", "City B", "City C", "City D"};
    static int minCost = Integer.MAX_VALUE;
    static String bestPath = "";

    public static String divideAndConquerMCOP(int[][] dist) {
        int n = dist.length;

        boolean[] visited = new boolean[n];
        visited[0] = true; // start at UPTM

        String path = locations[0];

        // Call helper
        divideAndConquerHelper(0, visited, 0, dist, n, path);

        return "Divide & Conquer Route: " + bestPath + " -> " + locations[0] +
               " | Total Cost: " + minCost;
    }
    
    private static void divideAndConquerHelper(int pos, boolean[] visited,
                                               int currentCost, int[][] dist,
                                               int n, String path) {

        if (allVisited(visited)) {
            int totalCost = currentCost + dist[pos][0];

            if (totalCost < minCost) {
                minCost = totalCost;
                bestPath = path;
            }
            return;
        }

        for (int i = 0; i < n; i++) {
            if (!visited[i]) {
                visited[i] = true;

                divideAndConquerHelper(
                    i,
                    visited,
                    currentCost + dist[pos][i],
                    dist,
                    n,
                    path + " -> " + locations[i]
                );

                visited[i] = false; // backtrack
            }
        }
    }

    private static boolean allVisited(boolean[] visited) {
        for (boolean v : visited) {
            if (!v) return false;
        }
        return true;
    }

    public static void main(String[] args) {
        System.out.println(divideAndConquerMCOP(costMatrix));
    }
}
